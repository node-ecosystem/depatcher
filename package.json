{
  "name": "depatcher",
  "version": "0.0.8",
  "description": "Dependencies patcher ~ apply patches to dependencies",
  "type": "module",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    "import": "./dist/index.mjs",
    "types": "./dist/index.d.mts"
  },
  "keywords": [
    "dependency",
    "dependencies",
    "patch",
    "patches"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/node-ecosystem/depatcher.git"
  },
  "bugs": {
